
upstream upload_v2_myfundaction {
    server 127.0.0.1:4009;
    keepalive 64;
}

server {
    listen 443 ssl;

    server_name 	upload-id-v2.myfundaction.org;
    ssl_certificate         /etc/ssl/certs/mfaid.pem; #path to your public key
    ssl_certificate_key     /etc/ssl/private/mfaid.key; #path to your private key

    client_max_body_size 100M;

    location / {
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Host $http_host;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_pass http://upload_v2_myfundaction/;
        proxy_redirect off;
        proxy_read_timeout 240s;
    }
}
